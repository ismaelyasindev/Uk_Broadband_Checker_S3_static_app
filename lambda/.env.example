# Local live API only — copy to .env.local (gitignored) and add your real key.
# Never commit .env.local.
OFCOM_API_KEY=

# Ofcom broadband API base (default matches api-proxy.ofcom.org.uk)
# OFCOM_API_BASE=https://api-proxy.ofcom.org.uk/broadband

# Optional: change the port (default 3001, must match frontend/vite.config.ts proxy)
# LOCAL_API_PORT=3001
