# -----------------------------------------------------------------------------
# Frontend runtime mode
# -----------------------------------------------------------------------------
# VITE_API_URL controls where broadband lookups are dispatched.
#
#   /demo   -> DEMO MODE. Data from /public/data/postcodes.json (no backend).
#   /api    -> LIVE MODE. Calls /api/check?pc=... (same origin behind CloudFront).
#
# NOTE: Vite inlines this at BUILD time. Do not put secrets here.
#       X-Origin-Verify is injected by CloudFront on origin requests, not the browser.
#
# /demo — bundled fixtures only (no backend)
# /api  — live lookups via Vite proxy → local API on :3001 (see lambda npm run dev:local)
VITE_API_URL=/demo
